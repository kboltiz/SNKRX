require "atmos.env.pico"
set pico = require "pico"

require "menu"

func GameLoop() {
    loop {
    	pico.push()
        val id = MainMenu()
        pico.pop() ;; cleans up menu buttons on transitions
        
        match id {
            :arena => await Arena()
            :quit  => return()
        }
    }
}

await GameLoop()
