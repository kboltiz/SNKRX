require "atmos.env.pico"
set pico = require "pico"

require "shared"
require "settings"

val Menu = require "menu"
val Arena = require "arena"

pico.set.window [ title="SNKRX Menu" ]
pico.set.dim [ '!', w=W, h=H ]

loop {
    pico.push()
    val id = await Menu()
    pico.pop() ;; cleans up menu buttons on transitions

    match id {
        :arena => await Arena()
        :quit  => break()
    }
}
